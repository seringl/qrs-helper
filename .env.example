# ── Required ────────────────────────────────────────────────────────────────
# Flask session signing key. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Bitly v4 OAuth token from https://app.bitly.com/settings/api
BITLY_API_TOKEN=

# Optional: pin a specific Bitly group GUID for created links. Leave unset to
# use the token's default group (find it in Bitly under Settings → API).
#BITLY_GROUP_GUID=

# ── Environment ─────────────────────────────────────────────────────────────
# production (default): Gunicorn, Secure cookies enforced, HTTPS required.
# development: debug + auto-reload, Secure cookie flags disabled so the app
#              can run on plain http://localhost:5000 without the nginx proxy.
FLASK_ENV=production

# ── Optional overrides (defaults are derived from the instance/ folder) ─────
# Leave DATABASE_URL unset for SQLite. The app derives an absolute path to
# <project-root>/instance/app.db at startup. Set explicitly only for
# PostgreSQL or MS SQL Server, e.g.:
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
#DATABASE_URL=

#UPLOAD_FOLDER=
#OUTPUT_FOLDER=
#MAX_UPLOAD_MB=5

# Username of the automatically created local administrator account
ADMIN_USERNAME=qrsadmin

# QRCode Monkey API base URL (override for testing/mocking)
#QRMONKEY_BASE_URL=https://api.qrcode-monkey.com

# ── LDAP (Phase 2 — leave disabled for demo/testing) ────────────────────────
LDAP_ENABLED=false
LDAP_SERVER=
LDAP_PORT=636
LDAP_USE_SSL=true
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_SEARCH_BASE=
LDAP_USER_ATTR_USERNAME=sAMAccountName
LDAP_USER_ATTR_EMAIL=mail
LDAP_USER_ATTR_NAME=displayName
LDAP_ALLOWED_GROUP=
